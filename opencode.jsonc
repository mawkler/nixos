{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "ask",
    "bash": {
      // keep-sorted start
      "*": "ask",
      "basename *": "allow",
      "cat *": "allow",
      "grep *": "allow",
      "ls *": "allow",
      "rg *": "allow",
      "sort *": "allow",
      "systemctl status *": "allow",
      // keep-sorted end
    },
  },
  "experimental": {
    "continue_loop_on_deny": true,
  },
}
