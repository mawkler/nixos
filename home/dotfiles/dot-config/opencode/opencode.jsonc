{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "ask",
    "bash": {
      // keep-sorted start
      "*": "ask",
      "arch *": "allow",
      "basename *": "allow",
      "cal *": "allow",
      "cargo build *": "allow",
      "cargo check *": "allow",
      "cargo clean *": "allow",
      "cargo clippy *": "allow",
      "cargo doc *": "allow",
      "cargo test *": "allow",
      "cat *": "allow",
      "cksum *": "allow",
      "column *": "allow",
      "cut *": "allow",
      "date *": "allow",
      "df *": "allow",
      "diff *": "allow",
      "dirname *": "allow",
      "du *": "allow",
      "echo *": "allow",
      "env *": "allow",
      "expand *": "allow",
      "factor *": "allow",
      "fd *": "allow",
      "file *": "allow",
      "fold *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git status *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "hexdump *": "allow",
      "hostname *": "allow",
      "id *": "allow",
      "jj diff *": "allow",
      "jj log *": "allow",
      "jj show *": "allow",
      "jj status *": "allow",
      "journalctl *": "allow",
      "jq *": "allow",
      "locate *": "allow",
      "ls *": "allow",
      "man *": "allow",
      "nix flake check *": "allow",
      "nix flake show *": "allow",
      "nix search *": "allow",
      "nix-instantiate *": "allow",
      "nix-store *": "allow",
      "nproc *": "allow",
      "od *": "allow",
      "printenv *": "allow",
      "printf *": "allow",
      "ps *": "allow",
      "pwd *": "allow",
      "readlink *": "allow",
      "realpath *": "allow",
      "rg *": "allow",
      "seq *": "allow",
      "sha256sum *": "allow",
      "sleep *": "allow",
      "sort *": "allow",
      "stat *": "allow",
      "systemctl status *": "allow",
      "tail *": "allow",
      "tty *": "allow",
      "type *": "allow",
      "uname *": "allow",
      "uniq *": "allow",
      "uptime *": "allow",
      "w *": "allow",
      "wc *": "allow",
      "whereis *": "allow",
      "which *": "allow",
      "who *": "allow",
      "whoami *": "allow",
      "xargs *": "allow",
      "xxd *": "allow",
      // keep-sorted end
    },
  },
  "experimental": {
    "continue_loop_on_deny": true,
  },
}
